@model List<student.Model.Student>
<h2>Student List</h2>
<a href="/Student/Create">Add Student</a>
<table border="1">
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Age</th>
    </tr>
@foreach (var s in Model)
    {
        <tr>
            <th>@s.Id</th>
            <td>@s.Name</td>
            <td>@s.Age</td>
        </tr>
    }
</table>